{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "target": "ES2020",
    "lib": [
      "ES2020",
      "DOM"
    ],
    "types": [
      "node"
    ],
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "paths": {
      "covara": [
        "../dist/index"
      ],
      "covara/node": [
        "../dist/server/node"
      ],
      "covara/client": [
        "../dist/client/index"
      ],
      "covara/client/react": [
        "../dist/client/react"
      ],
      "covara/env": [
        "../dist/env/index"
      ],
      "covara/*": [
        "../dist/*"
      ],
      "@/*": [
        "../dist/*"
      ]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}