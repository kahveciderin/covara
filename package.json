{
  "name": "covara",
  "version": "0.10.0",
  "description": "Real-time resource API framework built on Hono — runs standalone (Node) and on Cloudflare Workers, with a TypeScript client",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "covara": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./resource": {
      "types": "./dist/resource/hook.d.ts",
      "import": "./dist/resource/hook.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js"
    },
    "./client/react": {
      "types": "./dist/client/react.d.ts",
      "import": "./dist/client/react.js"
    },
    "./tasks": {
      "types": "./dist/tasks/index.d.ts",
      "import": "./dist/tasks/index.js"
    },
    "./kv": {
      "types": "./dist/kv/index.d.ts",
      "import": "./dist/kv/index.js"
    },
    "./oidc": {
      "types": "./dist/oidc/index.d.ts",
      "import": "./dist/oidc/index.js"
    },
    "./search": {
      "types": "./dist/search/index.d.ts",
      "import": "./dist/search/index.js"
    },
    "./db": {
      "types": "./dist/db/index.d.ts",
      "import": "./dist/db/index.js"
    },
    "./email": {
      "types": "./dist/email/index.d.ts",
      "import": "./dist/email/index.js"
    },
    "./billing": {
      "types": "./dist/billing/index.d.ts",
      "import": "./dist/billing/index.js"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "import": "./dist/storage/index.js"
    },
    "./openapi": {
      "types": "./dist/openapi/index.d.ts",
      "import": "./dist/openapi/index.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js"
    },
    "./middleware/observability": {
      "types": "./dist/middleware/observability.d.ts",
      "import": "./dist/middleware/observability.js"
    },
    "./middleware/rateLimit": {
      "types": "./dist/middleware/rateLimit.d.ts",
      "import": "./dist/middleware/rateLimit.js"
    },
    "./middleware/error": {
      "types": "./dist/middleware/error.d.ts",
      "import": "./dist/middleware/error.js"
    },
    "./middleware/logging": {
      "types": "./dist/middleware/logging.d.ts",
      "import": "./dist/middleware/logging.js"
    },
    "./middleware/securityHeaders": {
      "types": "./dist/middleware/securityHeaders.d.ts",
      "import": "./dist/middleware/securityHeaders.js"
    },
    "./env": {
      "types": "./dist/env/index.d.ts",
      "import": "./dist/env/index.js"
    },
    "./node": {
      "types": "./dist/server/node.d.ts",
      "import": "./dist/server/node.js"
    },
    "./server": {
      "types": "./dist/server/app.d.ts",
      "import": "./dist/server/app.js"
    },
    "./htmx": {
      "types": "./dist/htmx/index.d.ts",
      "import": "./dist/htmx/index.js"
    }
  },
  "files": [
    "dist",
    "assets",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json && tsc-alias -p tsconfig.json --resolve-full-paths",
    "prepublishOnly": "npm run build && npm run test",
    "start": "node dist/index.js",
    "lint": "eslint 'src/**/*.ts'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "example:dev": "pnpm build && (pnpm example:frontend:build || true) && tsx watch --tsconfig example/tsconfig.json example/src/main.ts",
    "example:server": "pnpm build && tsx watch --tsconfig example/tsconfig.json example/src/main.ts",
    "example:start": "node example/dist/main.js",
    "example:build": "tsc -p example/tsconfig.json && tsc-alias -p example/tsconfig.json",
    "example:frontend:install": "cd example/frontend && pnpm install",
    "example:frontend:build": "cd example/frontend && pnpm build",
    "example:frontend:dev": "cd example/frontend && pnpm dev",
    "example:setup": "pnpm build && pnpm example:frontend:install && pnpm example:frontend:build",
    "example:db:push": "drizzle-kit push",
    "example:typegen": "tsx example/scripts/typegen.ts"
  },
  "keywords": [
    "api",
    "rest",
    "realtime",
    "hono",
    "cloudflare-workers",
    "edge",
    "drizzle",
    "orm",
    "crud",
    "typescript",
    "sse",
    "subscriptions",
    "oidc",
    "authentication",
    "background-tasks",
    "offline-first"
  ],
  "author": "covara",
  "license": "---",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kahveciderin/covara.git"
  },
  "homepage": "https://kahveciderin.github.io/covara",
  "bugs": {
    "url": "https://github.com/kahveciderin/covara/issues"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@opensearch-project/opensearch": "^3.5.1",
    "cron-parser": "^5.4.0",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.12.25",
    "jsonwebtoken": "^9.0.3",
    "uuid": "^13.0.0"
  },
  "peerDependencies": {
    "drizzle-orm": ">=0.30.0",
    "react": ">=18.0.0",
    "zod": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.15",
    "@libsql/client": "^0.17.0",
    "htmx.org": "2.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.0.8",
    "@types/react": "^18.3.12",
    "@types/uuid": "^10.0.0",
    "better-sqlite3": "^12.6.0",
    "drizzle-kit": "^0.31.8",
    "drizzle-orm": "^0.45.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.2",
    "fast-check": "^4.5.3",
    "prettier": "^3.8.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^3.1.4",
    "zod": "^4.3.5"
  }
}
